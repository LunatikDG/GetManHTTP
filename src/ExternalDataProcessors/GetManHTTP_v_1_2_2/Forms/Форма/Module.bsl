
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ПолноеИмяОбработки = РеквизитФормыВЗначение("Объект").Метаданные().ПолноеИмя();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриЗакрытии(ЗавершениеРаботы)
	
	ОтключитьОбработчикОжидания("АвтосохранениеНастроек");
	
	// При завершении работы платформы хранилище системных настроек недоступно.
	Если Не ЗавершениеРаботы Тогда
		СохранитьНастройкиОбработки();
	КонецЕсли;
	
КонецПроцедуры


&НаКлиенте
Процедура ПриОткрытии(Отказ)

	ВосстановитьНастройкиОбработки();
	ОтобразитьВариантТелаЗапроса();
	СкрытьГруппыАвторизаций();
	ТипАвторизацииПриИзменении(Неопределено);
	
	ПодключитьОбработчикОжидания("АвтосохранениеНастроек", 30, Ложь);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура ТипАвторизацииПриИзменении(Элемент)
	
	СкрытьГруппыАвторизаций();
	
	Если ТипАвторизации = "BasicAuth" Тогда
		Элементы.ЛогинПароль.Видимость = Истина;
	ИначеЕсли ТипАвторизации = "Token" Тогда
		Элементы.ГруппаТокен.Видимость = Истина;
	Иначе
		Элементы.ЛогинПароль.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ТелоЗапросаПриИзменении(Элемент)
	БьютифицированныйЗапрос(ТелоЗапроса, "ТелоЗапроса", ВариантТелаЗапроса);
КонецПроцедуры

&НаКлиенте
Процедура ВариантТелаЗапросаПриИзменении(Элемент)
	ОтобразитьВариантТелаЗапроса();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура Отправить(Команда)
	
	ПроверкаУсловий = УсловияОтправкиВыполнены();
	
	Если ПроверкаУсловий.УсловияВыполнены  Тогда
		ОтправитьHTTPЗапросАсинх(СтруктураURI(URI));
	Иначе
		ВывестиСообщениеПользователю("Запрос не может быть отправлен, поскольку не все обязательные поля были заполнены");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьВходящийФайл(Команда)
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выберите файл который хотите передать";
	Диалог.Показать(Новый ОписаниеОповещения("ВыбратьФайлЗавершение", ЭтотОбъект));
	
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьОтветВФайл(Команда)
	
	Если ПустаяСтрока(ЗапросОтвет) Тогда
		ВывестиСообщениеПользователю("Нет данных для сохранения");
		Возврат;
	КонецЕсли;
	
	ФорматОтвета = ФорматОтветаДляСохранения;
	Если ПустаяСтрока(ФорматОтвета) Тогда
		ФорматОтвета = ОпределитьФорматОтветаДляСохранения();
	КонецЕсли;
	
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Заголовок = "Сохранить результат запроса";
	ЗаполнитьПараметрыДиалогаСохраненияПоФормату(Диалог, ФорматОтвета);
	Диалог.Показать(Новый ОписаниеОповещения("СохранитьОтветВФайлЗавершение", ЭтотОбъект));
	
КонецПроцедуры

&НаКлиенте
Процедура Настройки(Команда)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("Таймаут", Таймаут);
	
	ОписаниеОповещения = Новый ОписаниеОповещения("НастройкиЗавершение", ЭтотОбъект);
	
	ОткрытьФорму(
		ПолноеИмяОбработки + ".Форма.ФормаНастроек",
		ПараметрыФормы,
		,
		,
		,
		,
		ОписаниеОповещения,
		РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	
КонецПроцедуры

&НаКлиенте
Процедура НастройкиЗавершение(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Таймаут = Результат;
	ПодключитьОбработчикОжидания("АвтосохранениеНастроек", 0.1, Истина);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// КЛИЕНТ

&НаКлиенте
Процедура АвтосохранениеНастроек()
	
	СохранитьНастройкиОбработки();
	
КонецПроцедуры

// Выводит текстовое сообщение пользователю через платформенный механизм.
//
// Параметры:
//  ТекстСообщения - Строка - Текст сообщения для отображения.
//
&НаКлиенте
Процедура ВывестиСообщениеПользователю(ТекстСообщения)
	
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = ТекстСообщения;
	Сообщение.Сообщить();
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбратьФайлЗавершение(ВыбранныеФайлы, Параметры) Экспорт
	
	Если ВыбранныеФайлы = Неопределено Тогда
		ВывестиСообщениеПользователю("Не выбрано ни одного файла");
		Возврат;
	КонецЕсли;
	
	ПутьКФайлуВх = ВыбранныеФайлы[0];
	
КонецПроцедуры

&НаКлиенте
Процедура СохранитьОтветВФайлЗавершение(ВыбранныеФайлы, Параметры) Экспорт
	
	Если ВыбранныеФайлы = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ПутьКФайлу = ВыбранныеФайлы[0];
	
	#Если НЕ ВебКлиент Тогда
		ЗаписьТекста = Новый ЗаписьТекста(ПутьКФайлу, КодировкаТекста.UTF8);
		ЗаписьТекста.Записать(ЗапросОтвет);
		ЗаписьТекста.Закрыть();
		ВывестиСообщениеПользователю("Ответ сохранён в файл: " + ПутьКФайлу);
	#Иначе
		ВывестиСообщениеПользователю("Сохранение в файл недоступно в веб-клиенте");
	#КонецЕсли
	
КонецПроцедуры

// Определяет формат ответа для диалога сохранения: сначала Content-Type, затем тело.
//
// Возвращаемое значение:
//  Строка - "JSON", "XML", "HTML" или пустая строка.
//
&НаКлиенте
Функция ОпределитьФорматОтветаДляСохранения()
	
	Возврат ОпределитьФорматСодержимого(ЗапросОтвет);
	
КонецФункции

// Определяет формат по заголовкам HTTP-ответа и телу.
//
&НаКлиенте
Функция ОпределитьФорматПоЗаголовкамИТелу(Знач Заголовки, Знач ТекстОтвета)
	
	ФорматИзЗаголовка = ОпределитьФорматПоСоответствиюЗаголовков(Заголовки);
	Если Не ПустаяСтрока(ФорматИзЗаголовка) Тогда
		Возврат ФорматИзЗаголовка;
	КонецЕсли;
	
	Возврат ОпределитьФорматСодержимого(ТекстОтвета);
	
КонецФункции

// Определяет формат по соответствию заголовков ответа.
//
&НаКлиенте
Функция ОпределитьФорматПоСоответствиюЗаголовков(Знач Заголовки)
	
	Если Заголовки = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	ЗначениеContentType = Заголовки.Получить("Content-Type");
	Если ЗначениеContentType = Неопределено Тогда
		ЗначениеContentType = Заголовки.Получить("content-type");
	КонецЕсли;
	
	Если ЗначениеContentType = Неопределено Тогда
		Возврат "";
	КонецЕсли;
	
	Возврат ФорматИзContentType(Строка(ЗначениеContentType));
	
КонецФункции

&НаКлиенте
Функция ФорматИзContentType(Знач ЗначениеContentType)
	
	Значение = НРег(Строка(ЗначениеContentType));
	
	Если СтрНайти(Значение, "json") > 0 Тогда
		Возврат "JSON";
	КонецЕсли;
	
	// html раньше xml нельзя для application/xhtml+xml — это HTML.
	Если СтрНайти(Значение, "html") > 0 Тогда
		Возврат "HTML";
	КонецЕсли;
	
	Если СтрНайти(Значение, "xml") > 0 Тогда
		Возврат "XML";
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

// Определяет формат текстового содержимого ответа.
//
// Параметры:
//  Содержимое - Строка - текст ответа.
//
// Возвращаемое значение:
//  Строка - "JSON", "XML", "HTML" или пустая строка, если формат не определён.
//
&НаКлиенте
Функция ОпределитьФорматСодержимого(Знач Содержимое)
	
	Текст = УбратьНевидимыйПрефикс(СокрЛП(Содержимое));
	
	Если ПустаяСтрока(Текст) Тогда
		Возврат "";
	КонецЕсли;
	
	Фрагмент = НРег(Лев(Текст, 1024));
	
	Если СтрНачинаетсяС(Текст, "{") ИЛИ СтрНачинаетсяС(Текст, "[") Тогда
		Возврат "JSON";
	КонецЕсли;
	
	// XML объявление важнее HTML-тегов внутри (например <title> в slideshow).
	Если СтрНачинаетсяС(Фрагмент, "<?xml") Тогда
		Возврат "XML";
	КонецЕсли;
	
	Если ЭтоHTMLСодержимое(Фрагмент) Тогда
		Возврат "HTML";
	КонецЕсли;
	
	Если СтрНачинаетсяС(Текст, "<") Тогда
		Возврат "XML";
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

// Удаляет BOM и прочие невидимые символы в начале строки.
//
&НаКлиенте
Функция УбратьНевидимыйПрефикс(Знач Текст)
	
	Пока СтрДлина(Текст) > 0 Цикл
		
		КодСимвола = КодСимвола(Текст, 1);
		
		// BOM, нулевой байт и прочие невидимые управляющие символы (кроме таб/CR/LF — их срежет СокрЛП).
		Если КодСимвола = 65279 ИЛИ КодСимвола = 65534 ИЛИ КодСимвола = 0 Тогда
			Текст = Сред(Текст, 2);
		Иначе
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СокрЛП(Текст);
	
КонецФункции

// Проверяет, похож ли текст на HTML (по начальному фрагменту в нижнем регистре).
//
&НаКлиенте
Функция ЭтоHTMLСодержимое(Знач ТекстНижнийРегистр)
	
	Если СтрНайти(ТекстНижнийРегистр, "<!doctype html") > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если СтрНайти(ТекстНижнийРегистр, "<html") > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если СтрНайти(ТекстНижнийРегистр, "<head") > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Если СтрНайти(ТекстНижнийРегистр, "<body") > 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

// Настраивает фильтр и расширение диалога сохранения по формату ответа.
// Индекс фильтра в платформе 0-based: 0=JSON, 1=XML, 2=HTML, 3=TXT.
//
// Параметры:
//  Диалог       - ДиалогВыбораФайла - диалог сохранения файла.
//  ФорматОтвета - Строка - "JSON", "XML", "HTML" или пустая строка.
//
&НаКлиенте
Процедура ЗаполнитьПараметрыДиалогаСохраненияПоФормату(Диалог, Знач ФорматОтвета)
	
	Диалог.Фильтр =
		"JSON (*.json)|*.json|"
		+ "XML (*.xml)|*.xml|"
		+ "HTML (*.html)|*.html|"
		+ "Текстовые файлы (*.txt)|*.txt|"
		+ "Все файлы (*.*)|*.*";
	
	Если ФорматОтвета = "JSON" Тогда
		РасширениеФайла = "json";
		ИндексТипа = 0;
	ИначеЕсли ФорматОтвета = "XML" Тогда
		РасширениеФайла = "xml";
		ИндексТипа = 1;
	ИначеЕсли ФорматОтвета = "HTML" Тогда
		РасширениеФайла = "html";
		ИндексТипа = 2;
	Иначе
		РасширениеФайла = "txt";
		ИндексТипа = 3;
	КонецЕсли;
	
	Диалог.ПолноеИмяФайла = "response." + РасширениеФайла;
	Диалог.Расширение = РасширениеФайла;
	Диалог.ИндексФильтра = ИндексТипа;
	
КонецПроцедуры

// Отображает нужный вариант тела запроса в зависимости от выбранного значения
//
&НаКлиенте
Процедура ОтобразитьВариантТелаЗапроса()
	
	Если ВариантТелаЗапроса = "JSON" ИЛИ ВариантТелаЗапроса = "XML" Тогда
		Элементы.ТелоЗапроса.Видимость = Истина;
		Элементы.ЗагрузитьВходящийФайл.Видимость = Ложь;
	ИначеЕсли ВариантТелаЗапроса = "BINARY" Тогда
		Элементы.ТелоЗапроса.Видимость = Ложь;
		Элементы.ЗагрузитьВходящийФайл.Видимость = Истина;
	Иначе
		Элементы.ТелоЗапроса.Видимость = Ложь;
		Элементы.ЗагрузитьВходящийФайл.Видимость = Ложь;
	КонецЕсли;
	
КонецПроцедуры

// Приводит значения реквизитов в формы к изначальному виду
//
&НаКлиенте
Процедура ЗначенияПоУмолчанию()
	
	ЗапросОтвет = "";
	КодОтвета = 0;
	ФорматОтветаДляСохранения = "";
	
КонецПроцедуры

// Записывает текст в бьютифицированном виде (JSON или XML).
//
// Параметры:
//	СтрокаОтвета - Строка - Текст для форматирования.
//	Поле         - Строка - Имя реквизита формы для записи результата.
//	Формат       - Строка - "JSON", "XML" или "AUTO" (определение формата автоматически).
//
&НаКлиенте
Процедура БьютифицированныйЗапрос(Знач СтрокаОтвета, Знач Поле, Знач Формат = "JSON")

	Если ПустаяСтрока(СтрокаОтвета) ИЛИ ПустаяСтрока(Поле) Тогда
		Возврат;
	КонецЕсли;
	
	#Если НЕ ВебКлиент Тогда
		
		Если Формат = "AUTO" Тогда
			
			ФорматированиеВыполнено = БьютифицироватьJSON(СтрокаОтвета, Поле);
			
			Если Не ФорматированиеВыполнено Тогда
				ФорматированиеВыполнено = БьютифицироватьXML(СтрокаОтвета, Поле);
			КонецЕсли;
			
			Если Не ФорматированиеВыполнено Тогда
				ЭтотОбъект[Поле] = СтрокаОтвета;
			КонецЕсли;
			
		ИначеЕсли Формат = "XML" Тогда
			
			Если Не БьютифицироватьXML(СтрокаОтвета, Поле) Тогда
				ЭтотОбъект[Поле] = СтрокаОтвета;
			КонецЕсли;
			
		Иначе
			
			Если Не БьютифицироватьJSON(СтрокаОтвета, Поле) Тогда
				ЭтотОбъект[Поле] = СтрокаОтвета;
			КонецЕсли;
			
		КонецЕсли;
		
	#Иначе
		ЭтотОбъект[Поле] = СтрокаОтвета;
	#КонецЕсли

КонецПроцедуры

&НаКлиенте
Функция БьютифицироватьJSON(Знач СтрокаJSON, Знач Поле)
	
	Попытка
		
		Чтение = Новый ЧтениеJSON;
		Чтение.УстановитьСтроку(СтрокаJSON);
		
		Данные = ПрочитатьJSON(Чтение);
		
		Запись = Новый ЗаписьJSON();
		ПараметрыJSON = Новый ПараметрыЗаписиJSON(, Символы.Таб);
		Запись.УстановитьСтроку(ПараметрыJSON);

		ЗаписатьJSON(Запись, Данные);
		
		ЭтотОбъект[Поле] = Запись.Закрыть();
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

&НаКлиенте
Функция БьютифицироватьXML(Знач СтрокаXML, Знач Поле)
	
	Попытка
		ЧтениеXML = Новый ЧтениеXML;
		ЧтениеXML.УстановитьСтроку(СтрокаXML);
		ПостроительDOM = Новый ПостроительDOM;
		ДокументDOM = ПостроительDOM.Прочитать(ЧтениеXML);
		ЗаписьXML = Новый ЗаписьXML;
		ЗаписьXML.УстановитьСтроку();
		ЗаписьDOM = Новый ЗаписьDOM;
		ЗаписьDOM.Записать(ДокументDOM, ЗаписьXML);
		ЭтотОбъект[Поле] = ЗаписьXML.Закрыть();
		Возврат Истина;
	Исключение
		Возврат Ложь;
	КонецПопытки;
	
КонецФункции

// Скрывает группы авторизаций на форме
//
&НаКлиенте
Процедура СкрытьГруппыАвторизаций()

	Элементы.ЛогинПароль.Видимость = Ложь;
	Элементы.ГруппаТокен.Видимость = Ложь;

КонецПроцедуры

// Сформировать заголовки запроса
// 
// Возвращаемое значение:
//	Произвольный - заголовки HTTP-запроса
//
&НаКлиенте
Функция ЗаголовкиЗапроса()

	ЗаголовкиЗапросаПользователя = ЗаголовкиВСоответствие();
	
	// Дополняем заголовки авторизацией
	Если ТипАвторизации = "Token" Тогда
		СтрокаТокена = ?(ПустаяСтрока(НаименованиеТокена), "Token ", НаименованиеТокена + " ") + ТокенАвторизации;
		ЗаголовкиЗапросаПользователя.Вставить("Authorization", СтрокаТокена);
	КонецЕсли;

	Возврат ЗаголовкиЗапросаПользователя;

КонецФункции

// Проверяет выполнение всех условий для отправки HTTP-запроса
//
// Возвращаемое значение:
//	Структура:
//		* УсловияВыполнены - Булево - Признак того может ли быть отправлен HTTP-запроса
//
&НаКлиенте
Функция УсловияОтправкиВыполнены()
	Результат = Новый Структура;
	
	Результат.Вставить("УсловияВыполнены", Ложь);
	
	
	// Проверяем поля
	Если НЕ ПустаяСтрока(URI) И НЕ ПустаяСтрока(HTTPМетод) Тогда
		Результат.УсловияВыполнены = Истина;
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Разбирает строку URI на составные части и возвращает в виде структуры.
// На основе RFC 3986.
//
// Параметры:
//  СтрокаURI - Строка - ссылка на ресурс в формате:
//                       <схема>://<логин>:<пароль>@<хост>:<порт>/<путь>?<параметры>#<якорь>.
//
// Возвращаемое значение:
//  Структура - составные части URI согласно формату:
//   * Схема        	- Строка - схема из URI.
//   * Логин         	- Строка - логин из URI.
//   * Пароль        	- Строка - пароль из URI.
//   * ИмяСервера    	- Строка - часть <хост>:<порт> из URI.
//   * Хост          	- Строка - хост из URI.
//   * Порт          	- Число, Неопределено - порт из URI.
//   * ПутьНаСервере 	- Строка - часть <путь>?<параметры>#<якорь> из URI.
//   * ТипАвторизации 	- Строка - Используемый тип авторизации
//
&НаКлиенте
Функция СтруктураURI(Знач СтрокаURI) Экспорт
	
	СтрокаURI = СокрЛП(СтрокаURI);
	
	// схема
	Схема = "";
	Позиция = СтрНайти(СтрокаURI, "://");
	Если Позиция > 0 Тогда
		Схема = НРег(Лев(СтрокаURI, Позиция - 1));
		СтрокаURI = Сред(СтрокаURI, Позиция + 3);
	КонецЕсли;
	
	// Строка соединения и путь на сервере.
	СтрокаСоединения = СтрокаURI;
	ПутьНаСервере = "";
	Позиция = СтрНайти(СтрокаСоединения, "/");
	Если Позиция > 0 Тогда
		ПутьНаСервере = Сред(СтрокаСоединения, Позиция + 1);
		СтрокаСоединения = Лев(СтрокаСоединения, Позиция - 1);
	КонецЕсли;
	
	// Информация пользователя и имя сервера.
	СтрокаАвторизации = "";
	ИмяСервера = СтрокаСоединения;
	Позиция = СтрНайти(СтрокаСоединения, "@");
	Если Позиция > 0 Тогда
		СтрокаАвторизации = Лев(СтрокаСоединения, Позиция - 1);
		ИмяСервера = Сред(СтрокаСоединения, Позиция + 1);
	КонецЕсли;
	
	// логин и пароль
	Логин = СтрокаАвторизации;
	Пароль = "";
	Позиция = СтрНайти(СтрокаАвторизации, ":");
	Если Позиция > 0 Тогда
		Логин = Лев(СтрокаАвторизации, Позиция - 1);
		Пароль = Сред(СтрокаАвторизации, Позиция + 1);
	КонецЕсли;
	
	// хост и порт
	Хост = ИмяСервера;
	Порт = "";
	Позиция = СтрНайти(ИмяСервера, ":");
	Если Позиция > 0 Тогда
		Хост = Лев(ИмяСервера, Позиция - 1);
		Порт = Сред(ИмяСервера, Позиция + 1);
		Если Не ТолькоЦифрыВСтроке(Порт) Тогда
			Порт = "";
		КонецЕсли;
	КонецЕсли;
	
	Результат = Новый Структура;
	Результат.Вставить("Схема", Схема);
	Результат.Вставить("Логин", Логин);
	Результат.Вставить("Пароль", Пароль);
	Результат.Вставить("ИмяСервера", ИмяСервера);
	Результат.Вставить("Хост", Хост);
	Результат.Вставить("Порт", ?(ПустаяСтрока(Порт), Неопределено, Число(Порт)));
	Результат.Вставить("ПутьНаСервере", ПутьНаСервере);
	Результат.Вставить("ТипАвторизации", "");
	
	ДополнитьАвторизациюВСтруктурURI(Результат);
	
	ДополнитьПараметрыЗапросаВСтруктуруURI(Результат);

	Возврат Результат;
	
	
КонецФункции

// Проверяет, содержит ли строка только цифры.
//
// Параметры:
//  Значение         - Строка - проверяемая строка.
//  Устаревший       - Булево - устаревший параметр, не используется.
//  ПробелыЗапрещены - Булево - если Ложь, то в строке допустимо наличие пробелов.
//
// Возвращаемое значение:
//   Булево - Истина - строка содержит только цифры или пустая, Ложь - строка содержит иные символы.
//
// Пример:
//  Результат = СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке("0123"); // Истина
//  Результат = СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке("0123abc"); // Ложь
//  Результат = СтроковыеФункцииКлиентСервер.ТолькоЦифрыВСтроке("01 2 3",, Ложь); // Истина
//
&НаКлиенте
Функция ТолькоЦифрыВСтроке(Знач Значение, Знач Устаревший = Истина, Знач ПробелыЗапрещены = Истина) Экспорт
	
	Если ТипЗнч(Значение) <> Тип("Строка") Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Если Не ПробелыЗапрещены Тогда
		Значение = СтрЗаменить(Значение, " ", "");
	КонецЕсли;
		
	Если СтрДлина(Значение) = 0 Тогда
		Возврат Истина;
	КонецЕсли;
	
	Цифры = "0123456789";
	
	Для Индекс = 1 По СтрДлина(Значение) Цикл
		
		Если СтрНайти(Цифры, Сред(Значение, Индекс, 1)) = 0 Тогда
			Возврат Ложь;
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат Истина;
	
КонецФункции

// Дополняет структуру URI авторизацией (Basic Auth)
// 
// Параметры:
//	URI - Структура:
//			- см. СтруктураURI
&НаКлиенте
Процедура ДополнитьАвторизациюВСтруктурURI(URI)

	URI.ТипАвторизации = ТипАвторизации;
	
	Если ТипАвторизации = "BasicAuth" Тогда
		URI.Логин = ЛогинBasicAuth;
		URI.Пароль = ПарольBasicAuth;
	КонецЕсли;

КонецПроцедуры

// Дополнить структуру URI параметрами запроса
// Параметры:
//	URI - Структура:
//			- см. СтруктураURI
&НаКлиенте
Процедура ДополнитьПараметрыЗапросаВСтруктуруURI(URI)

	URI.ПутьНаСервере = URI.ПутьНаСервере + ПараметрыВСтроку();

КонецПроцедуры

// Отправка HTTP-запроса по указанным данным пользователем
// Параметры:
//	URI - Структура:
//			- см. СтруктураURI
//
&НаКлиенте
Асинх Процедура ОтправитьHTTPЗапросАсинх(URI)
	
	ЗначенияПоУмолчанию();
	ТекстОтвета = "";
	
	HTTPСоединение = СоздатьHTTPСоединение(URI);
	
	HTTPЗапрос = Новый HTTPЗапрос(URI.ПутьНаСервере);
	
	СформироватьТелоЗапроса(HTTPЗапрос);
	
	
	HTTPЗапрос.Заголовки = ЗаголовкиЗапроса();
	
	СтартЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Обещание  = HTTPСоединение.ВызватьHTTPМетодАсинх(HTTPМетод, HTTPЗапрос);
	
	Результат = Ждать Обещание;
	
	КонецЗамера = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	ВремяВыполненияЗапроса = Строка(КонецЗамера - СтартЗамера) + " ms";
	
	КодОтвета = Результат.КодСостояния;
	
	ЗаполнитьЗаголовкиОтвета(Результат.Заголовки);
	
	Если Результат.КодСостояния = 200 Тогда
		ТекстОтвета = Результат.ПолучитьТелоКакСтроку()
	Иначе
		ТекстОтвета = Результат.ПолучитьТелоКакСтроку();
	КонецЕсли;

	ФорматОтветаДляСохранения = ОпределитьФорматПоЗаголовкамИТелу(Результат.Заголовки, ТекстОтвета);
	БьютифицированныйЗапрос(ТекстОтвета, "ЗапросОтвет", "AUTO");
	
КонецПроцедуры

// Создаёт HTTP-соединение с учётом схемы, авторизации и таймаута из настроек.
//
// Параметры:
//  URI - Структура - см. СтруктураURI.
//
// Возвращаемое значение:
//  HTTPСоединение - готовое соединение для выполнения запроса.
//
&НаКлиенте
Функция СоздатьHTTPСоединение(URI)
	
	Порт = URI.Порт;
	Если Порт = Неопределено Тогда
		Если URI.Схема = "https" Тогда
			Порт = 443;
		Иначе
			Порт = 80;
		КонецЕсли;
	КонецЕсли;
	
	ТаймаутСоединения = Таймаут;
	Если ТаймаутСоединения = Неопределено Тогда
		ТаймаутСоединения = 30;
	КонецЕсли;
	
	ЗащищенноеСоединение = Неопределено;
	Если URI.Схема = "https" Тогда
		ЗащищенноеСоединение = Новый ЗащищенноеСоединениеOpenSSL();
	КонецЕсли;
	
	Если URI.ТипАвторизации = "BasicAuth" Тогда
		Возврат Новый HTTPСоединение(
			URI.Хост,
			Порт,
			URI.Логин,
			URI.Пароль,
			,
			ТаймаутСоединения,
			ЗащищенноеСоединение);
	Иначе
		Возврат Новый HTTPСоединение(
			URI.Хост,
			Порт,
			,
			,
			,
			ТаймаутСоединения,
			ЗащищенноеСоединение);
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура СформироватьТелоЗапроса(HTTPЗапроса)
	
	Если ВариантТелаЗапроса = "JSON" ИЛИ ВариантТелаЗапроса = "XML" Тогда
		Если ЗначениеЗаполнено(ТелоЗапроса) Тогда
			HTTPЗапроса.УстановитьТелоИзСтроки(ТелоЗапроса);
		КонецЕсли;
	ИначеЕсли ВариантТелаЗапроса = "BINARY" Тогда
		Если ЗначениеЗаполнено(ПутьКФайлуВх) Тогда
			HTTPЗапроса.УстановитьТелоИзДвоичныхДанных(Новый ДвоичныеДанные(ПутьКФайлуВх));
		Иначе
			ВывестиСообщениеПользователю("Предупреждение! Не выбран файл для отправки!");
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры


// СЕРВЕР

// Процедура заполняет реквизит формы заголовков из соответствия
//
// Параметры:
//	Соответствие - Произвольный - Заголовки результата запроса
//
&НаСервере
Процедура ЗаполнитьЗаголовкиОтвета(Знач Соответствие)

	ЗаголовкиОтвета.Загрузить(СоответствиеВЗаголовки(Соответствие));

КонецПроцедуры

// Преобразует таблицу значений в массив структур.
// Может использоваться для передачи на клиент данных в том случае, если таблица
// значений содержит только такие значения, которые могут
// быть переданы с сервера на клиент.
//
// Полученный массив содержит структуры, каждая из которых повторяет
// структуру колонок таблицы значений.
//
// Не рекомендуется использовать для преобразования таблиц значений
// с большим количеством строк.
//
// Возвращаемое значение:
//  Произвольный - коллекция строк таблицы в виде структур.
//
&НаСервере
Функция ЗаголовкиВСоответствие()
    // Создаем пустое соответствие
    Соответствие = Новый Соответствие;
    ЗаголовкиЗапросаТЗ = ЗаголовкиЗапроса.Выгрузить();
    // Проверка наличия строк в таблице
    Если ЗаголовкиЗапросаТЗ.Количество() = 0 Тогда
        Возврат Соответствие; // Возвращаем пустое соответствие
    КонецЕсли;
    
    // Проходим по всем строкам таблицы значений
    Для Каждого Строка Из ЗаголовкиЗапросаТЗ Цикл
        // Проверяем наличие хотя бы двух столбцов
        Если ЗаголовкиЗапросаТЗ.Колонки.Количество() >= 2 Тогда
            Ключ = Строка[0];
            Значение = Строка[1];
            // Добавляем в соответствие
            Соответствие.Вставить(Ключ, Значение);
        КонецЕсли;
    КонецЦикла;
    
    // Возвращаем готовое соответствие
    Возврат Соответствие;
КонецФункции

// Преобразует таблицу значений в массив структур.
// Может использоваться для передачи на клиент данных в том случае, если таблица
// значений содержит только такие значения, которые могут
// быть переданы с сервера на клиент.
//
// Полученный массив содержит структуры, каждая из которых повторяет
// структуру колонок таблицы значений.
//
// Не рекомендуется использовать для преобразования таблиц значений
// с большим количеством строк.
//
// Параметры:
//  Соответствие - Соответствие - коллекция строк таблицы в виде структур.
//  
// Возвращаемое значение:
// 	ТаблицаЗначений:
// 		* КлючЗаголовка - Строка - Ключ соответствия
// 		* ЗначениеЗаголовка - Строка - Значение соответствия
// 		* ОписаниеЗаголовка - Строка - Описание ключа соответствия
//
&НаСервере
Функция СоответствиеВЗаголовки(Знач Соответствие)
	
	ТЗ_Заголовки = Новый ТаблицаЗначений();
	ТЗ_Заголовки.Колонки.Добавить("КлючЗаголовка");
	ТЗ_Заголовки.Колонки.Добавить("ЗначениеЗаголовка");
	ТЗ_Заголовки.Колонки.Добавить("ОписаниеЗаголовка");
	
    // Проходим по всем строкам таблицы значений
    Для Каждого Элемент Из Соответствие Цикл
    	
    	НоваяСтрока = ТЗ_Заголовки.Добавить();
    	
    	НоваяСтрока.КлючЗаголовка = Элемент.Ключ;
    	НоваяСтрока.ЗначениеЗаголовка = Элемент.Значение;
    	
    КонецЦикла;
    
    Возврат ТЗ_Заголовки;
    
КонецФункции

&НаСервере
Функция ПараметрыВСтроку()
	
	СтрокаПараметров = "";
	
	ТаблицаПараметров = ПараметрыЗапроса.Выгрузить();
	
	Для Каждого Параметр Из ТаблицаПараметров Цикл
	
		СтрокаПараметров = СтрокаПараметров + СтрШаблон("%1=%2&", Параметр[0], Параметр[1]);
	
	КонецЦикла;
	
	Если НЕ ПустаяСтрока(СтрокаПараметров) Тогда
		СтрокаПараметров = "?" + Лев(СтрокаПараметров, СтрДлина(СтрокаПараметров)-1);
	КонецЕсли;
	
	Возврат СтрокаПараметров;
	
КонецФункции

&НаСервере
Функция ПолучитьИмяОбработки()
	
	Если ПустаяСтрока(ПолноеИмяОбработки) Тогда
		ПолноеИмяОбработки = РеквизитФормыВЗначение("Объект").Метаданные().ПолноеИмя();
	КонецЕсли;
	
	Возврат ПолноеИмяОбработки;
	
КонецФункции

&НаСервере
Функция КлючХраненияНастроекОбработки()
	
	Возврат ПолучитьИмяОбработки() + ".ПользовательскиеНастройки";
	
КонецФункции


#Область НастройкиОбработки

&НаСервере
Процедура СохранитьНастройкиОбработки()

	Настройки = Новый Соответствие();
	
	Настройки.Вставить("HTTPМетод", HTTPМетод);
	Настройки.Вставить("URI", URI);
	Настройки.Вставить("ТелоЗапроса", ТелоЗапроса);
	Настройки.Вставить("ВремяВыполненияЗапроса", ВремяВыполненияЗапроса);
	Настройки.Вставить("ЗаголовкиЗапроса", ЗначениеВСтрокуВнутр(ЗаголовкиЗапроса.Выгрузить()));
	Настройки.Вставить("ЗаголовкиОтвета", ЗначениеВСтрокуВнутр(ЗаголовкиОтвета.Выгрузить()));
	Настройки.Вставить("ЗапросОтвет", ЗапросОтвет);
	Настройки.Вставить("КодОтвета", КодОтвета);
	Настройки.Вставить("ЛогинBasicAuth", ЛогинBasicAuth);
	Настройки.Вставить("НаименованиеТокена", НаименованиеТокена);
	Настройки.Вставить("ПараметрыЗапроса", ЗначениеВСтрокуВнутр(ПараметрыЗапроса.Выгрузить()));
	Настройки.Вставить("ПарольBasicAuth", ПарольBasicAuth);
	Настройки.Вставить("ТипАвторизации", ТипАвторизации);
	Настройки.Вставить("ТокенАвторизации", ТокенАвторизации);
	Настройки.Вставить("ВариантТелаЗапроса", ВариантТелаЗапроса);
	Настройки.Вставить("ПутьКФайлуВх", ПутьКФайлуВх);
	Настройки.Вставить("Таймаут", Таймаут);
	
	ХранилищеСистемныхНастроек.Сохранить(КлючХраненияНастроекОбработки(), "Основные", Настройки);

КонецПроцедуры

&НаСервере
Процедура ВосстановитьНастройкиОбработки()

	НастройкиФормы = ХранилищеСистемныхНастроек.Загрузить(КлючХраненияНастроекОбработки(), "Основные");
	
	// Совместимость со старым ключом формы.
	Если НастройкиФормы = Неопределено Тогда
		Попытка
			НастройкиФормы = ХранилищеСистемныхНастроек.Загрузить(
				ПолучитьИмяОбработки() + ".Форма.Форма/ТекущиеДанные");
		Исключение
			НастройкиФормы = Неопределено;
		КонецПопытки;
	КонецЕсли;
	
	Если НастройкиФормы = Неопределено Тогда
		Таймаут = 30;
		Возврат;
	КонецЕсли;
	
	HTTPМетод = НастройкиФормы.Получить("HTTPМетод");
	URI = НастройкиФормы.Получить("URI");
	ТелоЗапроса = НастройкиФормы.Получить("ТелоЗапроса");
	ВремяВыполненияЗапроса = НастройкиФормы.Получить("ВремяВыполненияЗапроса");
	// Заголовки запроса
	ЗаголовкиЗапроса_ХР = НастройкиФормы.Получить("ЗаголовкиЗапроса");
	Если ЗаголовкиЗапроса_ХР <> Неопределено Тогда
